# ============================================================================
# AI Business OS — Variables de entorno (raiz / docker-compose)
# Copiar a .env y ajustar. Las claves aqui alimentan docker-compose.yml.
# ============================================================================

# --- PostgreSQL ---
POSTGRES_USER=aibos
POSTGRES_PASSWORD=aibos
POSTGRES_DB=aibos
POSTGRES_PORT=5432

# --- Puertos publicados en el host ---
API_PORT=3001
WEB_PORT=3000

# --- Autenticacion (JWT) ---
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=1d
