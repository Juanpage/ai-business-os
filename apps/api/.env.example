# ============================================================================
# AI Business OS — API (.env.example)
# Copiar a .env y ajustar los valores.
# ============================================================================

# --- Base de datos (PostgreSQL) ---
# En docker-compose el host es "postgres"; en local suele ser "localhost".
DATABASE_URL="postgresql://aibos:aibos@localhost:5432/aibos?schema=public"

# --- Servidor ---
PORT=3001

# --- Autenticacion (JWT) ---
JWT_SECRET="cambia-este-secreto-en-produccion"
JWT_EXPIRES_IN="1d"
